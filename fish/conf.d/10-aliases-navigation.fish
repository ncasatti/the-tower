# ====================
# Directory Navigation Aliases
# ====================
# Quick shortcuts to common directories

# System directories
abbr -a home 'cd ~'
abbr -a etc 'cd /etc/'
abbr -a music 'cd ~/Music'
abbr -a vids 'cd ~/Videos'
abbr -a conf 'cd ~/.config'
abbr -a temp 'cd ~/Temp'
abbr -a desk 'cd ~/Desktop'
abbr -a pics 'cd ~/Pictures'
abbr -a dldz 'cd ~/Downloads'
abbr -a docs 'cd ~/Documents'
abbr -a sapps 'cd /usr/share/applications'
abbr -a lapps 'cd ~/.local/share/applications'

# File manager
abbr -a y yazi

# Development directories
abbr -a dev 'cd ~/Documents/Development'
abbr -a devp 'cd ~/Documents/Development/Python'
abbr -a devf 'cd ~/Documents/Development/Frontend'
abbr -a deve 'cd ~/Documents/Development/Python/.venv'
abbr -a devem 'cd ~/Documents/Development/Emser'
abbr -a deva 'cd ~/Documents/Development/AndroidStudio'
abbr -a devr 'cd ~/Documents/Development/React'
abbr -a devdb 'cd ~/Documents/Development/DB'
abbr -a devdbmy 'cd ~/Documents/Development/DB/MySql'
